#include <winver.h>
#include "app/resource.h"

// Application icon – ID 1 so the shell uses it as the default .exe icon
IDI_HYPERBROWSE  ICON  "@CMAKE_CURRENT_SOURCE_DIR@/assets/HyperBrowse.ico"
IDB_HYPERBROWSE_BRAND_PNG  RCDATA  "@CMAKE_CURRENT_SOURCE_DIR@/assets/HyperBrowse_256.png"
IDR_TOOLBAR_ICON_OPEN_FOLDER  RCDATA  "@CMAKE_CURRENT_SOURCE_DIR@/assets/toolbar-icons/open-folder.svg"
IDR_TOOLBAR_ICON_RECURSIVE  RCDATA  "@CMAKE_CURRENT_SOURCE_DIR@/assets/toolbar-icons/recursive.svg"
IDR_TOOLBAR_ICON_VIEW_GRID  RCDATA  "@CMAKE_CURRENT_SOURCE_DIR@/assets/toolbar-icons/view-grid.svg"
IDR_TOOLBAR_ICON_VIEW_LIST  RCDATA  "@CMAKE_CURRENT_SOURCE_DIR@/assets/toolbar-icons/view-list.svg"
IDR_TOOLBAR_ICON_SORT  RCDATA  "@CMAKE_CURRENT_SOURCE_DIR@/assets/toolbar-icons/sort.svg"
IDR_TOOLBAR_ICON_THUMBNAIL_SIZE  RCDATA  "@CMAKE_CURRENT_SOURCE_DIR@/assets/toolbar-icons/thumbnail-size.svg"
IDR_TOOLBAR_ICON_COPY  RCDATA  "@CMAKE_CURRENT_SOURCE_DIR@/assets/toolbar-icons/copy.svg"
IDR_TOOLBAR_ICON_MOVE  RCDATA  "@CMAKE_CURRENT_SOURCE_DIR@/assets/toolbar-icons/move.svg"
IDR_TOOLBAR_ICON_DELETE  RCDATA  "@CMAKE_CURRENT_SOURCE_DIR@/assets/toolbar-icons/delete.svg"
IDR_TOOLBAR_ICON_SEARCH  RCDATA  "@CMAKE_CURRENT_SOURCE_DIR@/assets/toolbar-icons/search.svg"
IDR_TOOLBAR_ICON_CHEVRON_DOWN  RCDATA  "@CMAKE_CURRENT_SOURCE_DIR@/assets/toolbar-icons/chevron-down.svg"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS__WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", "HyperBrowse"
            VALUE "FileDescription", "HyperBrowse native Win32 image browser"
            VALUE "FileVersion", "@PROJECT_VERSION@.0"
            VALUE "InternalName", "HyperBrowse.exe"
            VALUE "OriginalFilename", "HyperBrowse.exe"
            VALUE "ProductName", "HyperBrowse"
            VALUE "ProductVersion", "@PROJECT_VERSION@.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END