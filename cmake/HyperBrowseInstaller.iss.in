#define AppName "HyperBrowse"
#define AppVersion "@PROJECT_VERSION@"
#define AppPublisher "@HYPERBROWSE_APP_PUBLISHER@"
#define AppPublisherURL "@HYPERBROWSE_APP_PUBLISHER_URL@"

#ifndef ReleaseLayout
  #error ReleaseLayout must point at the staged Runtime install layout.
#endif

#ifndef OutputDir
  #error OutputDir must point at the desired installer output directory.
#endif

[Setup]
AppId={{5F5955D7-336A-4B2A-BB2B-6578334E17BF}
AppName={#AppName}
AppVersion={#AppVersion}
AppPublisher={#AppPublisher}
AppPublisherURL={#AppPublisherURL}
AppSupportURL={#AppPublisherURL}
AppUpdatesURL={#AppPublisherURL}
DefaultDirName={autopf}\{#AppName}
DefaultGroupName={#AppName}
DisableProgramGroupPage=yes
PrivilegesRequired=lowest
PrivilegesRequiredOverridesAllowed=dialog
ArchitecturesAllowed=x64compatible
ArchitecturesInstallIn64BitMode=x64compatible
Compression=lzma2/max
SolidCompression=yes
WizardStyle=modern
SetupLogging=yes
OutputDir={#OutputDir}
OutputBaseFilename=HyperBrowse-@PROJECT_VERSION@-installer
SetupIconFile=@HYPERBROWSE_APP_ICON_PATH@
UninstallDisplayIcon={app}\bin\HyperBrowse.exe
UninstallDisplayName={#AppName}
VersionInfoVersion={#AppVersion}
VersionInfoProductName={#AppName}
VersionInfoProductVersion={#AppVersion}

[Languages]
Name: "english"; MessagesFile: "compiler:Default.isl"

[Tasks]
Name: "desktopicon"; Description: "{cm:CreateDesktopIcon}"; GroupDescription: "{cm:AdditionalIcons}"

[Files]
Source: "{#ReleaseLayout}\*"; DestDir: "{app}"; Flags: ignoreversion recursesubdirs createallsubdirs

[Icons]
Name: "{group}\HyperBrowse"; Filename: "{app}\bin\HyperBrowse.exe"; WorkingDir: "{app}\bin"; IconFilename: "{app}\bin\HyperBrowse.exe"; Comment: "Launch HyperBrowse"
Name: "{group}\Uninstall HyperBrowse"; Filename: "{uninstallexe}"
Name: "{autodesktop}\HyperBrowse"; Filename: "{app}\bin\HyperBrowse.exe"; WorkingDir: "{app}\bin"; IconFilename: "{app}\bin\HyperBrowse.exe"; Tasks: desktopicon